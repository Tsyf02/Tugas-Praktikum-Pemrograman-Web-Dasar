/* TABLE */
function getFiltered() {
  const q  = (document.getElementById('search-input')?.value || '').toLowerCase();
  const rt = document.getElementById('filter-rt')?.value || '';
  const st = document.getElementById('filter-status')?.value || '';
  return wargaData.filter(w => {
    const matchQ  = !q  || w.nama.toLowerCase().includes(q);
    const matchRt = !rt || w.rt === rt;
    const matchSt = !st || w.status === st;
    return matchQ && matchRt && matchSt;
  });
}

function renderTable() {
  const filtered = getFiltered();
  const total = filtered.length;
  const totalPages = Math.ceil(total / PER_PAGE);
  if (currentPage > totalPages) currentPage = Math.max(1, totalPages);
  const start = (currentPage - 1) * PER_PAGE;
  const pageData = filtered.slice(start, start + PER_PAGE);

  const body = document.getElementById('table-body');
  if (!body) return;
  body.innerHTML = pageData.map((w, i) => `
    <tr>
      <td>${start + i + 1}</td>
      <td><strong>${w.nama}</strong><br><small style="color:var(--text-muted)">${w.nik}</small></td>
      <td>${w.usia} thn</td>
      <td>${w.gender === 'L' ? (currentLang==='id'?'♂ L':'♂ M') : '♀ P'}</td>
      <td>${w.rt}</td>
      <td><span class="badge badge-${w.status.toLowerCase()}">${translateStatus(w.status)}</span></td>
      <td>${w.dis === 'Tidak Ada' ? `<span style="color:var(--text-muted);font-size:.8rem">${t('opt_nodis')}</span>` : w.dis}</td>
      <td>${w.bantuan === 'Tidak Ada' ? `<span style="color:var(--text-muted);font-size:.8rem">—</span>` : w.bantuan}</td>
      <td>
        <div class="action-group">
          <button class="tbl-btn edit" onclick="openEditModal(${w.id})">${t('lbl_edit')}</button>
          <button class="tbl-btn delete" onclick="deleteRow(${w.id})">${t('lbl_hapus')}</button>
        </div>
      </td>
    </tr>
  `).join('');

  // Pagination info
  const info = document.getElementById('pagination-info');
  if (info) info.textContent = `${t('pagination_show')} ${start+1}–${Math.min(start+PER_PAGE, total)} ${t('pagination_of')} ${total} ${t('pagination_data')}`;

  // Pagination buttons
  const btns = document.getElementById('pagination-btns');
  if (btns) {
    let html = '';
    for (let i = 1; i <= totalPages; i++) {
      html += `<button class="page-btn${i===currentPage?' active':''}" onclick="goPage(${i})">${i}</button>`;
    }
    btns.innerHTML = html;
  }
  updateSummary();
}

function translateStatus(s) {
  if (s === 'Sehat') return t('opt_sehat');
  if (s === 'Sakit') return t('opt_sakit');
  if (s === 'Stabil') return t('opt_stabil');
  return s;
}
function filterTable() { currentPage = 1; renderTable(); }
function goPage(p) { currentPage = p; renderTable(); }

function updateSummary() {
  const totalLansia = wargaData.length;
  const totalDis = wargaData.filter(w => w.dis !== 'Tidak Ada').length;
  const sehat = wargaData.filter(w => w.status === 'Sehat').length;
  const bantuan = wargaData.filter(w => w.bantuan !== 'Tidak Ada').length;
  const set = (id, val) => { const el = document.getElementById(id); if(el) el.textContent = val; };
  set('card-lansia', totalLansia);
  set('card-disabilitas', totalDis);
  set('card-sehat', sehat);
  set('card-bantuan', bantuan);
  set('strip-lansia', totalLansia);
  set('strip-disabilitas', totalDis);
}

