function t(key) { return i18n[currentLang][key] || key; }

function applyTranslations() {
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    if (i18n[currentLang][key] !== undefined) el.innerHTML = i18n[currentLang][key];
  });
  document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
    const key = el.getAttribute('data-i18n-placeholder');
    if (i18n[currentLang][key] !== undefined) el.placeholder = i18n[currentLang][key];
  });
  document.getElementById('lang-btn').textContent = currentLang === 'id' ? 'EN' : 'ID';
  document.querySelector('html').lang = currentLang;
  renderTable();
  updateCharts();
}

function toggleLang() {
  currentLang = currentLang === 'id' ? 'en' : 'id';
  applyTranslations();
}

/*THEME Websitenya*/
let isDark = false;
function toggleTheme() {
  isDark = !isDark;
  document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
  document.getElementById('theme-btn').textContent = isDark ? '☀️' : '🌙';
  updateCharts();
}

/* NAVIGATION*/
function switchPage(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-link').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  document.querySelectorAll('[onclick*="switchPage(\'' + page + '\')"]').forEach(el => el.classList.add('active'));
  window.scrollTo(0, 0);
  if (page === 'statistik') { setTimeout(initCharts, 100); }
  if (page === 'data') renderTable();
}
function toggleMobile() {
  document.getElementById('mobile-nav').classList.toggle('open');
}

/* TABLE*/
function getFiltered() {
  const q  = (document.getElementById('search-input')?.value || '').toLowerCase();
  const rt = document.getElementById('filter-rt')?.value || '';
  const st = document.getElementById('filter-status')?.value || '';
  return wargaData.filter(w => {
    const matchQ  = !q  || w.nama.toLowerCase().includes(q);
    const matchRt = !rt || w.rt === rt;
    const matchSt = !st || w.status === st;
    return matchQ && matchRt && matchSt;
  });
}

function renderTable() {
  const filtered = getFiltered();
  const total = filtered.length;
  const totalPages = Math.ceil(total / PER_PAGE);
  if (currentPage > totalPages) currentPage = Math.max(1, totalPages);
  const start = (currentPage - 1) * PER_PAGE;
  const pageData = filtered.slice(start, start + PER_PAGE);

  const body = document.getElementById('table-body');
  if (!body) return;
  body.innerHTML = pageData.map((w, i) => `
    <tr>
      <td>${start + i + 1}</td>
      <td><strong>${w.nama}</strong><br><small style="color:var(--text-muted)">${w.nik}</small></td>
      <td>${w.usia} thn</td>
      <td>${w.gender === 'L' ? (currentLang==='id'?'♂ L':'♂ M') : '♀ P'}</td>
      <td>${w.rt}</td>
      <td><span class="badge badge-${w.status.toLowerCase()}">${translateStatus(w.status)}</span></td>
      <td>${w.dis === 'Tidak Ada' ? `<span style="color:var(--text-muted);font-size:.8rem">${t('opt_nodis')}</span>` : w.dis}</td>
      <td>${w.bantuan === 'Tidak Ada' ? `<span style="color:var(--text-muted);font-size:.8rem">—</span>` : w.bantuan}</td>
      <td>
        <div class="action-group">
          <button class="tbl-btn edit" onclick="openEditModal(${w.id})">${t('lbl_edit')}</button>
          <button class="tbl-btn delete" onclick="deleteRow(${w.id})">${t('lbl_hapus')}</button>
        </div>
      </td>
    </tr>
  `).join('');

  // Pagination info
  const info = document.getElementById('pagination-info');
  if (info) info.textContent = `${t('pagination_show')} ${start+1}–${Math.min(start+PER_PAGE, total)} ${t('pagination_of')} ${total} ${t('pagination_data')}`;

  // Pagination buttons
  const btns = document.getElementById('pagination-btns');
  if (btns) {
    let html = '';
    for (let i = 1; i <= totalPages; i++) {
      html += `<button class="page-btn${i===currentPage?' active':''}" onclick="goPage(${i})">${i}</button>`;
    }
    btns.innerHTML = html;
  }
  updateSummary();
}

function translateStatus(s) {
  if (s === 'Sehat') return t('opt_sehat');
  if (s === 'Sakit') return t('opt_sakit');
  if (s === 'Stabil') return t('opt_stabil');
  return s;
}
function filterTable() { currentPage = 1; renderTable(); }
function goPage(p) { currentPage = p; renderTable(); }

function updateSummary() {
  const totalLansia = wargaData.length;
  const totalDis = wargaData.filter(w => w.dis !== 'Tidak Ada').length;
  const sehat = wargaData.filter(w => w.status === 'Sehat').length;
  const bantuan = wargaData.filter(w => w.bantuan !== 'Tidak Ada').length;
  const set = (id, val) => { const el = document.getElementById(id); if(el) el.textContent = val; };
  set('card-lansia', totalLansia);
  set('card-disabilitas', totalDis);
  set('card-sehat', sehat);
  set('card-bantuan', bantuan);
  set('strip-lansia', totalLansia);
  set('strip-disabilitas', totalDis);
}

/*MODAL NYA*/
function openAddModal() {
  editingId = null;
  document.getElementById('modal-title').innerHTML = t('modal_add_title');
  clearForm();
  document.getElementById('modal-overlay').classList.add('show');
  switchPage('data');
}
function openEditModal(id) {
  editingId = id;
  const w = wargaData.find(x => x.id === id);
  if (!w) return;
  document.getElementById('modal-title').innerHTML = t('modal_edit_title');
  document.getElementById('f-nama').value   = w.nama;
  document.getElementById('f-nik').value    = w.nik;
  document.getElementById('f-usia').value   = w.usia;
  document.getElementById('f-gender').value = w.gender;
  document.getElementById('f-rt').value     = w.rt;
  document.getElementById('f-status').value = w.status;
  document.getElementById('f-dis').value    = w.dis;
  document.getElementById('f-bantuan').value= w.bantuan;
  document.getElementById('f-alamat').value = w.alamat;
  document.getElementById('f-kontak').value = w.kontak;
  document.getElementById('modal-overlay').classList.add('show');
}
function closeModal() {
  document.getElementById('modal-overlay').classList.remove('show');
  editingId = null;
}
function clearForm() {
  ['f-nama','f-nik','f-usia','f-alamat','f-kontak'].forEach(id => {
    document.getElementById(id).value = '';
  });
}
function saveData() {
  const nama = document.getElementById('f-nama').value.trim();
  if (!nama) { showToast('⚠️ Nama wajib diisi!', 'danger'); return; }
  const obj = {
    id:      editingId || nextId++,
    nama,
    nik:     document.getElementById('f-nik').value,
    usia:    parseInt(document.getElementById('f-usia').value) || 60,
    gender:  document.getElementById('f-gender').value,
    rt:      document.getElementById('f-rt').value,
    status:  document.getElementById('f-status').value,
    dis:     document.getElementById('f-dis').value,
    bantuan: document.getElementById('f-bantuan').value,
    alamat:  document.getElementById('f-alamat').value,
    kontak:  document.getElementById('f-kontak').value,
  };
  if (editingId) {
    const idx = wargaData.findIndex(w => w.id === editingId);
    if (idx !== -1) wargaData[idx] = obj;
  } else {
    wargaData.push(obj);
  }
  closeModal();
  renderTable();
  showToast(t('toast_saved'), 'success');
}
function deleteRow(id) {
  if (!confirm(t('confirm_delete'))) return;
  wargaData = wargaData.filter(w => w.id !== id);
  renderTable();
  showToast(t('toast_deleted'), 'danger');
}

/* EXPORT CSV (DATA BISA KE EXCEL)*/
function exportCSV() {
  const headers = ['No','Nama','NIK','Usia','JK','RT','Status','Disabilitas','Bantuan','Alamat','Kontak'];
  const rows = wargaData.map((w,i) => [
    i+1, w.nama, w.nik, w.usia, w.gender, w.rt, w.status, w.dis, w.bantuan, w.alamat, w.kontak
  ]);
  const csv = [headers, ...rows].map(r => r.map(c => `"${c}"`).join(',')).join('\n');
  const blob = new Blob([csv], { type: 'text/csv' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'data-warga-desa.csv'; a.click();
  URL.revokeObjectURL(url);
  showToast(t('toast_exported'), 'info');
}

/*GRAFIK DATA USER*/
let charts = {};
let chartsInited = false;

function getCSSVar(name) {
  return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
}

function initCharts() {
  if (chartsInited) { updateCharts(); return; }
  chartsInited = true;
  buildAgeChart();
  buildDisChart();
  buildHealthChart();
  buildRtChart();
}

function buildAgeChart() {
  const ctx = document.getElementById('ageChart');
  if (!ctx) return;
  charts.age = new Chart(ctx, {
    type: 'bar',
    data: getAgeData(),
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { ticks: { color: getCSSVar('--text-muted') }, grid: { color: getCSSVar('--border') } },
        y: { ticks: { color: getCSSVar('--text-muted') }, grid: { color: getCSSVar('--border') } },
      }
    }
  });
}
function buildDisChart() {
  const ctx = document.getElementById('disChart');
  if (!ctx) return;
  charts.dis = new Chart(ctx, {
    type: 'doughnut',
    data: getDisData(),
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'right', labels: { color: getCSSVar('--text'), font: { size: 11 } } } }
    }
  });
}
function buildHealthChart() {
  const ctx = document.getElementById('healthChart');
  if (!ctx) return;
  charts.health = new Chart(ctx, {
    type: 'pie',
    data: getHealthData(),
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'bottom', labels: { color: getCSSVar('--text'), font: { size: 11 } } } }
    }
  });
}
function buildRtChart() {
  const ctx = document.getElementById('rtChart');
  if (!ctx) return;
  charts.rt = new Chart(ctx, {
    type: 'bar',
    data: getRtData(),
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { ticks: { color: getCSSVar('--text-muted') }, grid: { color: getCSSVar('--border') } },
        y: { ticks: { color: getCSSVar('--text-muted') }, grid: { color: getCSSVar('--border') } },
      }
    }
  });
}

function getAgeData() {
  const ranges = {'60–64':0,'65–69':0,'70–74':0,'75–79':0,'80+':0};
  wargaData.forEach(w => {
    if (w.usia < 65) ranges['60–64']++;
    else if (w.usia < 70) ranges['65–69']++;
    else if (w.usia < 75) ranges['70–74']++;
    else if (w.usia < 80) ranges['75–79']++;
    else ranges['80+']++;
  });
  return {
    labels: Object.keys(ranges),
    datasets: [{ data: Object.values(ranges), backgroundColor: ['#3B82F6','#60A5FA','#93C5FD','#BFDBFE','#DBEAFE'],
      borderRadius: 6, hoverBackgroundColor: '#1A56DB' }]
  };
}
function getDisData() {
  const types = {};
  wargaData.forEach(w => {
    if (w.dis !== 'Tidak Ada') types[w.dis] = (types[w.dis]||0)+1;
  });
  const colors = ['#3B82F6','#10B981','#F59E0B','#EF4444','#8B5CF6','#06B6D4'];
  return { labels: Object.keys(types), datasets: [{ data: Object.values(types), backgroundColor: colors, hoverOffset: 6 }] };
}
function getHealthData() {
  const sehat  = wargaData.filter(w => w.status === 'Sehat').length;
  const sakit  = wargaData.filter(w => w.status === 'Sakit').length;
  const stabil = wargaData.filter(w => w.status === 'Stabil').length;
  return {
    labels: [t('opt_sehat'), t('opt_sakit'), t('opt_stabil')],
    datasets: [{ data: [sehat, sakit, stabil], backgroundColor: ['#10B981','#EF4444','#F59E0B'], hoverOffset: 6 }]
  };
}
function getRtData() {
  const rts = {'RT 01':0,'RT 02':0,'RT 03':0,'RT 04':0};
  wargaData.forEach(w => { if (rts[w.rt] !== undefined) rts[w.rt]++; });
  return {
    labels: Object.keys(rts),
    datasets: [{ data: Object.values(rts), backgroundColor: ['#3B82F6','#10B981','#F59E0B','#8B5CF6'],
      borderRadius: 6 }]
  };
}
function updateCharts() {
  if (!chartsInited) return;
  const textColor = getCSSVar('--text');
  const mutedColor = getCSSVar('--text-muted');
  const borderColor = getCSSVar('--border');
  const updateOpts = (chart, newData) => {
    chart.data = newData;
    if (chart.options.scales) {
      ['x','y'].forEach(ax => {
        if (chart.options.scales[ax]) {
          chart.options.scales[ax].ticks.color = mutedColor;
          chart.options.scales[ax].grid.color = borderColor;
        }
      });
    }
    if (chart.options.plugins?.legend) {
      chart.options.plugins.legend.labels = { ...chart.options.plugins.legend.labels, color: textColor };
    }
    chart.update();
  };
  if (charts.age)    updateOpts(charts.age,    getAgeData());
  if (charts.dis)    updateOpts(charts.dis,    getDisData());
  if (charts.health) updateOpts(charts.health, getHealthData());
  if (charts.rt)     updateOpts(charts.rt,     getRtData());
}

function switchChart(idx, btn) {
  const ids = ['chart-age-wrap','chart-dis-wrap','chart-health-wrap','chart-rt-wrap'];
  if (idx === 0) { ids.forEach(id => { document.getElementById(id).style.display = 'block'; }); }
  else { ids.forEach((id,i) => { document.getElementById(id).style.display = (i === idx-1 ? 'block' : 'none'); }); }
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

/* TOAST */
function showToast(msg, type = 'info') {
  const c = document.getElementById('toast-container');
  const t2 = document.createElement('div');
  t2.className = `toast ${type}`;
  t2.innerHTML = msg;
  c.appendChild(t2);
  setTimeout(() => { t2.style.opacity = '0'; t2.style.transition = 'opacity .4s'; setTimeout(() => t2.remove(), 400); }, 3000);
}

